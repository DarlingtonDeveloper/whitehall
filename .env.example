# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJ...  # Anon key — safe for client-side, RLS-enforced
# SUPABASE_SERVICE_ROLE_KEY=eyJ...                   # Server-side only — bypasses RLS. Optional for POC.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...                          # Required for chat, report enrichment, web search, forward scan

# App URL (for OG image resolution)
# NEXT_PUBLIC_APP_URL=https://whitehall.vercel.app

# Observability (optional)
# OPIK_API_KEY=                                       # Forwards traces to Opik alongside Supabase logging
# OPIK_API_URL=http://localhost:5173                  # Opik endpoint

# Cron protection (when implemented)
# CRON_SECRET=your-random-secret
